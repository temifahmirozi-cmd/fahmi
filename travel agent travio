<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travio - Jelajahi Keindahan Indonesia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        html { scroll-behavior: smooth; }
        .hero-gradient { background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.5)); }
        .text-travio-blue { color: #0056b3; }
        .bg-travio-orange { background-color: #ff9800; }
    </style>
</head>
<body class="bg-slate-50 font-sans text-gray-800">

    <nav class="bg-white/95 backdrop-blur-md shadow-md sticky top-0 z-50">
        <div class="container mx-auto px-6 py-2 flex justify-between items-center">
            <a href="#" class="flex items-center">
                <img src="https://lh3.googleusercontent.com/d/1Uv_f_93Fh-I2zI9_I-Wn_C7p1O7G8n26" alt="Logo Travio" class="h-16 w-auto">
                <span class="ml-2 text-2xl font-black tracking-tighter text-blue-700 hidden sm:block">TRAVIO</span>
            </a>
            
            <div class="hidden md:flex space-x-8 font-semibold text-gray-600">
                <a href="#home" class="hover:text-blue-600 transition">Beranda</a>
                <a href="#destinasi" class="hover:text-blue-600 transition">Destinasi</a>
                <a href="#contact" class="hover:text-blue-600 transition">Kontak</a>
            </div>
            
            <a href="https://wa.me/6285876371055" class="bg-orange-500 text-white px-6 py-2 rounded-full font-bold hover:bg-orange-600 transition shadow-lg shadow-orange-200">
                Hubungi Kami
            </a>
        </div>
    </nav>

    <header id="home" class="relative h-[85vh] flex items-center justify-center text-center text-white">
        <div class="absolute inset-0 hero-gradient z-10"></div>
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1537996194471-e657df975ab4?ixlib=rb-1.2.1&auto=format&fit=crop&w=1600&q=80')] bg-cover bg-center"></div>
        
        <div class="relative z-20 px-4 max-w-4xl">
            <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight drop-shadow-lg">Jelajahi Nusantara Bersama Travio</h1>
            <p class="text-lg md:text-xl mb-10 opacity-95 font-light">Solusi perjalanan terpercaya untuk mengeksplorasi keindahan Indonesia.</p>
            <div class="flex flex-col md:flex-row justify-center gap-4">
                <a href="#destinasi" class="bg-blue-700 text-white px-10 py-4 rounded-xl font-bold text-lg hover:bg-blue-800 transition shadow-xl">Cari Paket Wisata</a>
                <a href="#contact" class="bg-white text-blue-900 px-10 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition">Cek Promo</a>
            </div>
        </div>
    </header>

    <section id="destinasi" class="py-20 bg-white">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-4xl font-bold text-gray-900 mb-4">Destinasi Unggulan</h2>
            <div class="w-24 h-1 bg-orange-500 mx-auto mb-12"></div>
            
            <div class="grid md:grid-cols-3 gap-8 text-left">
                <div class="group overflow-hidden rounded-2xl shadow-lg border border-gray-100">
                    <div class="h-60 overflow-hidden relative">
                        <img src="https://images.unsplash.com/photo-1555400038-63f5ba517a47?auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Bali">
                        <div class="absolute bottom-4 left-4 bg-orange-500 text-white px-3 py-1 rounded font-bold">Bali</div>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Wonderful Ubud</h3>
                        <p class="text-gray-600 text-sm">Rasakan ketenangan di jantung budaya Bali.</p>
                    </div>
                </div>

                <div class="group overflow-hidden rounded-2xl shadow-lg border border-gray-100">
                    <div class="h-60 overflow-hidden relative">
                        <img src="https://images.unsplash.com/photo-1516690561799-46d8f74f9abf?auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Raja Ampat">
                        <div class="absolute bottom-4 left-4 bg-orange-500 text-white px-3 py-1 rounded font-bold">Papua</div>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Exotic Raja Ampat</h3>
                        <p class="text-gray-600 text-sm">Menyelami keajaiban bawah laut dunia.</p>
                    </div>
                </div>

                <div class="group overflow-hidden rounded-2xl shadow-lg border border-gray-100">
                    <div class="h-60 overflow-hidden relative">
                        <img src="https://images.unsplash.com/photo-1596402184320-417d7178b2cd?auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Labuan Bajo">
                        <div class="absolute bottom-4 left-4 bg-orange-500 text-white px-3 py-1 rounded font-bold">NTT</div>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Sailing Labuan Bajo</h3>
                        <p class="text-gray-600 text-sm">Eksplorasi Pulau Komodo dengan kapal Phinisi.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="py-20 bg-slate-100">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row">
                <div class="bg-blue-700 p-10 text-white md:w-2/5">
                    <h3 class="text-2xl font-bold mb-6">Informasi Kontak</h3>
                    <div class="space-y-6">
                        <div class="flex items-center">
                            <i class="fas fa-envelope mr-4 text-orange-400"></i>
                            <span>temifahmirozi@gmail.com</span>
                        </div>
                        <div class="flex items-center">
                            <i class="fas fa-phone mr-4 text-orange-400"></i>
                            <span>085876371055</span>
                        </div>
                        <div class="pt-6">
                            <p class="text-sm opacity-80">Alamat Kantor:</p>
                            <p class="font-medium">Indonesia</p>
                        </div>
                    </div>
                </div>
                <div class="p-10 md:w-3/5">
                    <form action="#">
                        <div class="mb-4">
                            <input type="text" placeholder="Nama Anda" class="w-full p-3 border border-gray-200 rounded-lg focus:outline-blue-500">
                        </div>
                        <div class="mb-4">
                            <input type="email" placeholder="Email Anda" class="w-full p-3 border border-gray-200 rounded-lg focus:outline-blue-500">
                        </div>
                        <div class="mb-6">
                            <textarea placeholder="Pesan Anda" rows="4" class="w-full p-3 border border-gray-200 rounded-lg focus:outline-blue-500"></textarea>
                        </div>
                        <button class="w-full bg-orange-500 text-white font-bold py-3 rounded-lg hover:bg-orange-600 transition">Kirim Pesan Sekarang</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-white py-12 border-t border-gray-100">
        <div class="container mx-auto px-6 flex flex-col items-center text-center">
            <img src="https://lh3.googleusercontent.com/d/1Uv_f_93Fh-I2zI9_I-Wn_C7p1O7G8n26" alt="Logo Travio Footer" class="h-24 w-auto mb-6">
            
            <p class="text-gray-500 max-w-md mb-8">Travio Travel Agent memberikan pengalaman wisata terbaik dengan harga transparan dan pelayanan profesional.</p>
            
            <div class="flex space-x-6 mb-8 text-gray-400">
                <a href="#" class="hover:text-blue-600 transition"><i class="fab fa-instagram fa-lg"></i></a>
                <a href="#" class="hover:text-blue-600 transition"><i class="fab fa-facebook fa-lg"></i></a>
                <a href="#" class="hover:text-blue-600 transition"><i class="fab fa-whatsapp fa-lg"></i></a>
            </div>
            
            <p class="text-xs text-gray-400 font-bold tracking-widest uppercase">
                &copy; 2026 TRAVIO TRAVEL AGENT | TEMI FAHMI ROZI
            </p>
        </div>
    </footer>

